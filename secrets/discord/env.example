# Set these in your environment or PowerShell profile.
#
#   $env:DISCORD_WEBHOOK_URL = "https://discord.com/api/webhooks/<channel-id>/<token>"
#   $env:DISCORD_BOT_TOKEN = "<bot-token>"
#   $env:DISCORD_API_URL = "https://discord.com/api/v10"  # optional
#
# Then dot-source the helpers from this repo:
#   . platform/windows/powershell/helpers/scripts/webhooks/curl_discord.ps1
#
# send_discord -Message "Hello from dotfiles"
# send_image -Path "C:\path\to\image.png"
# get_discord -ChannelId "<channel-id>"
